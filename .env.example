# Copy to .env.local (never commit .env.local)

# Enable gate on Vercel (leave unset/false for local `npx serve`)
ACCESS_GATE_ENABLED=true

# Same value as Vercel → Settings → Environment Variables
ACCESS_TOKEN_SECRET=

# Your Vercel production URL (no trailing slash)
SITE_BASE_URL=https://your-app.vercel.app

# Session lifetime after successful unlock (hours) — Vercel only
SESSION_HOURS=24
